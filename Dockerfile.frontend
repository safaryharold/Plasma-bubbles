FROM node:18-alpine

WORKDIR /app

# Copy package files
COPY frontend/package.json frontend/yarn.lock ./

# Install dependencies
RUN yarn install --frozen-lockfile

# Copy frontend code
COPY frontend/ .

# Build the application
RUN yarn build

# Expose port
EXPOSE 3000

# Serve the built app
RUN yarn global add serve
CMD ["serve", "-s", "build", "-l", "3000"]